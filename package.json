{
  "name": "ecosistema-tic-manizales",
  "type": "module",
  "version": "1.0.0",
  "description": "Mapa del ecosistema TIC de Manizales y Caldas: empresas, universidades, programas, personas, comunidades y eventos.",
  "license": "CC-BY-SA-4.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate:data && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "validate:data": "tsx scripts/validate-data.ts",
    "audit:data": "tsx scripts/audit-data.ts",
    "validate:urls": "node scripts/validate-urls.mjs",
    "verify:companies": "node scripts/verify-companies.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.1.0",
    "@fontsource-variable/newsreader": "^5.1.0",
    "@fontsource-variable/public-sans": "^5.1.0",
    "astro": "^5.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@astrojs/react": "^4.3.0",
    "@astrojs/sitemap": "^3.4.0",
    "@astrojs/tailwind": "^6.0.2",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "playwright": "^1.49.0",
    "typescript-eslint": "^8.20.0",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
