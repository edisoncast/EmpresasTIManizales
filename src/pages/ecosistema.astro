---
import Layout from '../components/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContributionCTA from '../components/ContributionCTA.astro';
import StatsGrid from '../components/StatsGrid.astro';
import {
  companies,
  universities,
  communities,
  people,
  stats,
  programsForUniversity,
} from '../lib/data';

// Conexiones reales presentes en los datos (sin inventar causalidad).
const uniConnections = universities
  .map((university) => ({
    university,
    programCount: programsForUniversity(university).length,
  }))
  .filter(({ programCount }) => programCount > 0)
  .sort((a, b) => b.programCount - a.programCount);
const activeCommunities = communities.filter((community) => community.status === 'active');
const companyCategories = [...new Set(companies.flatMap((company) => company.categories))]
  .map((category) => ({
    category,
    count: companies.filter((company) => company.categories.includes(category)).length,
  }))
  .sort((a, b) => b.count - a.count || a.category.localeCompare(b.category, 'es'))
  .slice(0, 6);
const peopleWithOrganizations = people.filter(
  (person) => person.organizations && person.organizations.length > 0,
).length;
const ecosystemStats = [
  { label: 'Empresas', value: stats.companies, href: '/empresas', note: 'fichas consolidadas' },
  { label: 'Instituciones', value: stats.universities, href: '/universidades' },
  { label: 'Programas', value: stats.programs, href: '/programas' },
  { label: 'Personas', value: stats.people, href: '/personas' },
  { label: 'Comunidades activas', value: activeCommunities.length, href: '/comunidades' },
  { label: 'Agenda', value: stats.events, href: '/eventos' },
];

const connections = [
  'La academia forma el talento que contratan las empresas.',
  'Las comunidades acercan a estudiantes, profesionales y empresas.',
  'Las personas referentes conectan universidad, empresa y comunidad.',
  'Las entidades de apoyo articulan y financian iniciativas del ecosistema.',
];
---

<Layout
  title="Mapa del ecosistema"
  description="Cómo se conectan los actores del ecosistema TIC de Manizales y Caldas: universidades, programas, empresas, personas, comunidades y entidades de apoyo."
>
  <PageHeader
    eyebrow="Relaciones"
    title="Mapa del ecosistema"
    description="El valor de este mapa no está solo en los registros, sino en las relaciones entre actores. Aquí mostramos las conexiones presentes hoy en los datos y cómo se articula el territorio."
    showCutoff={false}
  />

  <section class="container-content py-10">
    <h2 class="sr-only">Registros actuales del ecosistema</h2>
    <StatsGrid
      stats={ecosystemStats}
      caption={`${peopleWithOrganizations} personas incluyen al menos una organización o comunidad en su ficha pública.`}
    />
  </section>

  <!-- Relaciones documentadas -->
  <section class="container-content border-t border-ink-200 py-12">
    <p class="kicker text-accent">Relaciones documentadas</p>
    <h2 class="mt-1 font-display text-2xl font-semibold text-ink-900">
      Vínculos sustentados por los datos
    </h2>
    <p class="mt-1 max-w-reading text-ink-600">
      Cada vínculo existe porque un registro lo respalda con su fuente. No inferimos relaciones que
      los datos no soporten.
    </p>

    <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
      <div class="rounded-lg border border-ink-200 bg-surface p-5">
        <h3 class="kicker">Institución → Programas</h3>
        <ul class="mt-3 space-y-2">
          {
            uniConnections.map(({ university, programCount }) => (
              <li class="flex items-baseline justify-between gap-3 text-sm">
                <a
                  href={`/universidades/${university.slug}`}
                  class="min-w-0 truncate text-ink-800 no-underline hover:text-accent"
                >
                  {university.name}
                </a>
                <span class="shrink-0 font-mono text-xs text-ink-500">{programCount}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="rounded-lg border border-ink-200 bg-surface p-5">
        <h3 class="kicker">Comunidades → Organización</h3>
        <ul class="mt-3 space-y-2">
          {
            activeCommunities.map((community) => (
              <li class="text-sm">
                <a
                  href={`/comunidades/${community.slug}`}
                  class="text-ink-800 no-underline hover:text-accent"
                >
                  {community.name}
                </a>
                <span class="block font-mono text-xs text-ink-500">
                  {community.organizer ?? 'Organización por documentar'}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Formas de explorar -->
  <section class="container-content border-t border-ink-200 py-12">
    <p class="kicker">Formas de explorar</p>
    <h2 class="mt-1 font-display text-2xl font-semibold text-ink-900">
      Empresas por categoría de actividad
    </h2>
    <p class="mt-1 max-w-reading text-ink-600">
      Una categoría es una etiqueta para explorar el directorio, no una relación entre actores ni
      una prueba de colaboración.
    </p>
    <div class="mt-6 flex flex-wrap gap-2">
      {
        companyCategories.map(({ category, count }) => (
          <a
            href={`/empresas?category=${encodeURIComponent(category)}`}
            class="inline-flex items-center gap-1.5 rounded-full border border-ink-200 bg-surface px-3 py-1 text-sm no-underline transition-colors duration-fast hover:border-accent"
          >
            <span class="text-ink-800">{category}</span>
            <span class="font-mono text-xs text-ink-500">{count}</span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Contexto del territorio -->
  <section class="container-content border-t border-ink-200 py-12">
    <p class="kicker">Contexto</p>
    <h2 class="mt-1 font-display text-2xl font-semibold text-ink-900">
      Cómo se articula el territorio
    </h2>
    <p class="mt-1 max-w-reading text-ink-600">
      Explicaciones generales del ecosistema, no evidencia sobre registros individuales.
    </p>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      {
        connections.map((connection) => (
          <div class="flex items-start gap-3 rounded-lg border border-ink-200 bg-surface p-4">
            <span
              aria-hidden="true"
              class="mt-1.5 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent"
            />
            <span class="text-sm text-ink-700">{connection}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Entidades de apoyo -->
  <section id="entidades" class="container-content border-t border-ink-200 py-12">
    <h2 class="font-display text-2xl font-semibold text-ink-900">Entidades de apoyo</h2>
    <p class="mt-3 max-w-reading text-ink-600">
      Gremios, cámaras de comercio, clústeres, incubadoras y entidades públicas que fomentan el
      ecosistema. Aún no hay registros documentados con fuente pública.
    </p>
    <div class="mt-6">
      <ContributionCTA variant="add" />
    </div>
  </section>
</Layout>
