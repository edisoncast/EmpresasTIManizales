---
import Layout from '../components/Layout.astro';
---

<Layout title="Página no encontrada" description="La página que buscas no existe.">
  <section class="container-content flex min-h-[50vh] flex-col items-center justify-center py-20 text-center">
    <p class="text-6xl font-black text-brand-600">404</p>
    <h1 class="mt-4 text-2xl font-bold text-ink-900">No encontramos esta página</h1>
    <p class="mt-2 max-w-md text-ink-600">
      Puede que el enlace esté roto o que el registro aún no exista en el repositorio.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn-primary">Volver al inicio</a>
      <a href="/ecosistema" class="btn-secondary">Explorar el ecosistema</a>
    </div>
  </section>
</Layout>
