---
import Layout from '../components/Layout.astro';
import GlobalSearch from '../components/GlobalSearch.astro';
import StatsGrid from '../components/StatsGrid.astro';
import TopoPattern from '../components/TopoPattern.astro';
import ContributionCTA from '../components/ContributionCTA.astro';
import PersonCard from '../components/PersonCard.astro';
import { stats, companies, universities, programs, people, communities } from '../lib/data';
import { site } from '../lib/site';
import { formatDate } from '../lib/format';
import {
  resolveVerification,
  verificationMeta,
  verificationOrder,
  type VerificationState,
} from '../lib/verification';

const cutoff = formatDate(site.auditDate);

const metrics = [
  { label: 'Empresas', value: stats.companies, href: '/empresas' },
  { label: 'Universidades', value: stats.universities, href: '/universidades' },
  { label: 'Programas', value: stats.programs, href: '/programas' },
  { label: 'Comunidades', value: stats.communities, href: '/comunidades' },
  { label: 'Personas', value: stats.people, href: '/personas' },
  { label: 'Agenda', value: stats.events, href: '/eventos' },
];

const index = [
  {
    n: '01',
    href: '/empresas',
    title: 'Empresas',
    count: stats.companies,
    text: 'Empresas de base tecnológica y casas de desarrollo de software.',
  },
  {
    n: '02',
    href: '/universidades',
    title: 'Universidades',
    count: stats.universities,
    text: 'Instituciones con formación en software, datos, redes y afines.',
  },
  {
    n: '03',
    href: '/programas',
    title: 'Programas',
    count: stats.programs,
    text: 'Técnicos, tecnológicos, pregrados y posgrados del área TIC.',
  },
  {
    n: '04',
    href: '/personas',
    title: 'Personas',
    count: stats.people,
    text: 'Trayectorias públicas que construyen ecosistema.',
  },
  {
    n: '05',
    href: '/comunidades',
    title: 'Comunidades',
    count: stats.communities,
    text: 'Meetups y comunidades técnicas de la región.',
  },
  {
    n: '06',
    href: '/eventos',
    title: 'Agenda',
    count: stats.events,
    text: 'Encuentros próximos, pasados y por verificar, dentro de Comunidad.',
  },
];

// Distribución de estados de verificación en todo el archivo.
const allEntities = [...companies, ...universities, ...programs, ...people, ...communities];
const dist: Record<VerificationState, number> = {
  verified: 0,
  partially_verified: 0,
  unknown: 0,
  inactive_or_unverified: 0,
  archived: 0,
};
for (const e of allEntities) dist[resolveVerification(e)]++;
const distTotal = allEntities.length;

const featuredPeople = people.slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  description: site.description,
  url: new URL('/', Astro.site ?? Astro.url).toString(),
};
---

<Layout jsonLd={jsonLd}>
  <!-- Hero editorial -->
  <section class="relative overflow-hidden border-b border-ink-200 bg-paper">
    <TopoPattern
      class="pointer-events-none absolute inset-x-0 bottom-0 hidden h-2/3 w-full text-brand-300/40 sm:block"
    />
    <div class="container-content relative py-16 sm:py-20 lg:py-24">
      <p class="kicker flex flex-wrap items-center gap-x-2 gap-y-1">
        <span>Observatorio abierto</span>
        <span aria-hidden="true">·</span>
        <span>Manizales &amp; Caldas</span>
      </p>
      <h1 class="mt-4 max-w-3xl font-display text-display font-semibold text-ink-900">
        Mapa abierto del ecosistema tecnológico de Manizales y Caldas
      </h1>
      <p class="mt-5 max-w-reading text-md leading-relaxed text-ink-700">
        Un lugar para consultar, relacionar y verificar quién construye tecnología en la región:
        empresas, universidades, programas, personas, comunidades y eventos. Datos abiertos,
        verificables y mantenidos por comunidad.
      </p>

      <div class="mt-8 max-w-xl">
        <GlobalSearch />
      </div>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <a href="/ecosistema" class="btn-primary">Explorar el mapa del ecosistema</a>
        <a href="/contribuir" class="btn-secondary">Contribuir con datos</a>
      </div>
    </div>
  </section>

  <!-- Nota histórica 2020 → 2026 -->
  <section class="bg-mist/50 border-b border-ink-200">
    <div
      class="container-content flex flex-col gap-3 py-6 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="max-w-2xl text-sm text-ink-700">
        <span class="font-mono text-xs text-coffee">{site.startedYear} → {site.currentYear}</span>
        &nbsp; Proyecto iniciado en {site.startedYear} como repositorio comunitario y revalidado comunitariamente
        en {site.currentYear}. Reconocemos lo que aún no está confirmado y lo convertimos en una
        invitación a contribuir.
      </p>
      <a
        href="/acerca"
        class="shrink-0 text-sm font-medium text-accent no-underline hover:underline"
        >Ver metodología →</a
      >
    </div>
  </section>

  <!-- Métricas del ecosistema -->
  <section class="container-content py-14" aria-labelledby="metricas">
    <div class="mb-6 flex items-baseline justify-between gap-4">
      <h2 id="metricas" class="font-display text-2xl font-semibold text-ink-900">
        El ecosistema en cifras
      </h2>
    </div>
    <StatsGrid
      stats={metrics}
      caption={`Cifras a corte de ${cutoff}. Son registros del archivo, no indicadores de desempeño ni un ranking.`}
    />
  </section>

  <!-- Accesos principales: índice editorial -->
  <section class="container-content py-6" aria-labelledby="explora">
    <h2 id="explora" class="font-display text-2xl font-semibold text-ink-900">
      Explora el archivo
    </h2>
    <p class="mt-1 max-w-reading text-ink-600">
      Siete tipos de registro conforman el mapa. Cada uno se explora, filtra y verifica por
      separado.
    </p>
    <ul class="mt-6 divide-y divide-ink-200 border-y border-ink-200">
      {
        index.map((it) => (
          <li>
            <a
              href={it.href}
              class="hover:bg-mist/40 group flex items-baseline gap-4 py-4 no-underline transition-colors duration-fast"
            >
              <span class="font-mono text-xs text-ink-400">{it.n}</span>
              <span class="flex-1">
                <span class="font-display text-lg font-semibold text-ink-900 group-hover:text-accent">
                  {it.title}
                </span>
                <span class="ml-2 font-mono text-xs text-ink-400">{it.count}</span>
                <span class="mt-0.5 block max-w-xl text-sm text-ink-600">{it.text}</span>
              </span>
              <span
                aria-hidden="true"
                class="text-ink-400 transition-transform duration-fast group-hover:translate-x-0.5"
              >
                →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Verificación -->
  <section class="bg-mist/40 border-y border-ink-200">
    <div class="container-content py-14" aria-labelledby="verificacion">
      <h2 id="verificacion" class="font-display text-2xl font-semibold text-ink-900">
        Cómo leemos la verificación
      </h2>
      <p class="mt-1 max-w-reading text-ink-600">
        Cada registro tiene un grado de confianza. No ocultamos la incertidumbre: la mostramos y la
        convertimos en una invitación a aportar fuentes.
      </p>
      <dl class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        {
          verificationOrder.map((s) => (
            <div class="rounded-lg border border-ink-200 bg-surface p-4">
              <dt class="flex items-center gap-2">
                <span class={`badge ${verificationMeta[s].badge}`}>
                  <span aria-hidden="true">{verificationMeta[s].symbol}</span>
                  {verificationMeta[s].label}
                </span>
              </dt>
              <dd class="mt-2 font-display text-2xl font-semibold tabular-nums text-ink-900">
                {dist[s]}
                <span class="ml-1 font-sans text-xs font-normal text-ink-500">de {distTotal}</span>
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Muestra de personas -->
  <section class="container-content py-14" aria-labelledby="personas">
    <div class="flex items-baseline justify-between gap-4">
      <h2 id="personas" class="font-display text-2xl font-semibold text-ink-900">
        Personas que construyen ecosistema
      </h2>
      <a
        href="/personas"
        class="shrink-0 text-sm font-medium text-accent no-underline hover:underline">Ver todas →</a
      >
    </div>
    <p class="mt-1 max-w-reading text-ink-600">
      Reconocimiento por trayectoria y contribuciones públicas, en orden alfabético. No es un
      ranking.
    </p>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {featuredPeople.map((p) => <PersonCard person={p} />)}
    </div>
  </section>

  <!-- CTA de contribución -->
  <section class="container-content pb-16">
    <ContributionCTA variant="general" />
  </section>
</Layout>
