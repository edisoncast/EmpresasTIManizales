---
export interface Props {
  title?: string;
  message?: string;
  ctaHref?: string;
  ctaLabel?: string;
  /** Si es un estado de "sin resultados de filtro", se marca para el script de filtros. */
  forFilters?: boolean;
}
const {
  title = 'Aún no hay registros',
  message = 'Este dato todavía no existe en el archivo. Puedes ser la primera persona en aportarlo con una fuente pública.',
  ctaHref = '/contribuir',
  ctaLabel = 'Sugerir un registro',
  forFilters = false,
} = Astro.props;
---

<div
  class="rounded-lg border border-dashed border-ink-300 bg-mist/50 px-6 py-14 text-center"
  data-empty-state={forFilters ? 'filters' : 'data'}
>
  <!-- Marca topográfica mínima -->
  <svg
    class="mx-auto h-10 w-16 text-ink-300"
    viewBox="0 0 64 40"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    aria-hidden="true"
  >
    <path d="M2 30c10-6 18-6 30-12s20-8 30-12" />
    <path d="M2 38c10-6 18-6 30-12s20-8 30-12" opacity="0.6" />
  </svg>
  <h2 class="mt-4 font-display text-xl font-semibold text-ink-900">{title}</h2>
  <p class="mx-auto mt-2 max-w-md text-sm text-ink-600">{message}</p>
  <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
    {
      forFilters && (
        <button type="button" class="btn-secondary" data-clear-filters-cta>
          Limpiar filtros
        </button>
      )
    }
    {ctaHref && <a href={ctaHref} class="btn-primary">{ctaLabel}</a>}
  </div>
</div>
