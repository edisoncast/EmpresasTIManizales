---
export interface Crumb {
  label: string;
  href?: string;
}
export interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav aria-label="Ruta de navegación" class="text-sm text-ink-500">
  <ol class="flex flex-wrap items-center gap-1.5">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {item.href ? (
            <a href={item.href} class="no-underline hover:text-brand-700">
              {item.label}
            </a>
          ) : (
            <span class="text-ink-700" aria-current="page">
              {item.label}
            </span>
          )}
          {i < items.length - 1 && <span aria-hidden="true">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
