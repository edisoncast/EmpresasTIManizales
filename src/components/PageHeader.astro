---
import { site } from '../lib/site';
import { formatDate } from '../lib/format';

export interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  /** Muestra la nota de corte temporal de la auditoría. */
  showCutoff?: boolean;
}
const { title, description, eyebrow, showCutoff = true } = Astro.props;
---

<div class="border-b border-ink-200 bg-paper">
  <div class="container-content py-10 sm:py-12">
    {eyebrow && <p class="kicker">{eyebrow}</p>}
    <h1 class="mt-2 max-w-3xl font-display text-3xl font-semibold leading-tight text-ink-900">
      {title}
    </h1>
    {
      description && (
        <p class="mt-3 max-w-reading text-balance text-md leading-relaxed text-ink-600">
          {description}
        </p>
      )
    }
    {
      showCutoff && (
        <p class="mt-4 inline-flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs text-ink-500">
          <span>Corte de datos: {formatDate(site.auditDate)}</span>
          <span aria-hidden="true">·</span>
          <a href="/acerca" class="text-accent no-underline hover:underline">
            Metodología
          </a>
        </p>
      )
    }
    <div class="mt-4">
      <slot />
    </div>
  </div>
</div>
