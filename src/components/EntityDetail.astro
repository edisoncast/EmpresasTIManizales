---
import VerificationStatus from './VerificationStatus.astro';
import ContributionCTA from './ContributionCTA.astro';
import Tag from './Tag.astro';
import { displayUrl } from '../lib/format';
import { resolveVerification, verificationMeta, type VerificationState } from '../lib/verification';

export interface Fact {
  label: string;
  value: string;
  mono?: boolean;
}
export interface LinkItem {
  label: string;
  href: string;
}
export interface SourceItem {
  /** `href` es el formato interno; `url` es el formato que usan los datasets. */
  href?: string;
  url?: string;
  title?: string;
  reviewedAt?: string;
}
export interface Props {
  title: string;
  eyebrow?: string;
  subtitle?: string;
  description?: string;
  notes?: string;
  needsVerification: boolean;
  verificationStatus?: VerificationState;
  status?: 'active' | 'inactive' | 'unknown';
  lastVerifiedAt?: string;
  sourceUrl?: string;
  sources?: SourceItem[];
  facts?: Fact[];
  links?: LinkItem[];
  tags?: string[];
  tagsLabel?: string;
  entityName?: string;
}
const {
  title,
  eyebrow,
  subtitle,
  description,
  notes,
  needsVerification,
  verificationStatus,
  status,
  lastVerifiedAt,
  sourceUrl,
  sources,
  facts = [],
  links = [],
  tags = [],
  tagsLabel = 'Etiquetas',
  entityName,
} = Astro.props;

const state = resolveVerification({ verificationStatus, needsVerification, status });
const showCallout =
  state === 'unknown' || state === 'partially_verified' || state === 'inactive_or_unverified';
const sourceList = (sources ?? (sourceUrl ? [{ href: sourceUrl }] : [])).flatMap((source) => {
  const href = source.href ?? source.url;
  return href ? [{ href, title: source.title, reviewedAt: source.reviewedAt }] : [];
});
---

<article class="container-detail py-8">
  <header class="border-b border-ink-200 pb-6">
    {eyebrow && <p class="kicker">{eyebrow}</p>}
    <h1 class="mt-2 font-display text-3xl font-semibold leading-tight text-ink-900">{title}</h1>
    {subtitle && <p class="mt-2 text-md text-ink-600">{subtitle}</p>}

    <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-2">
      <VerificationStatus
        verificationStatus={verificationStatus}
        needsVerification={needsVerification}
        status={status}
        lastVerifiedAt={lastVerifiedAt}
        variant="inline"
      />
    </div>

    {
      showCallout && (
        <p class="mt-4 rounded-md border border-partial/30 bg-partial-bg/50 p-3 text-sm text-ink-800">
          <strong>{verificationMeta[state].label}.</strong> {verificationMeta[state].message}{' '}
          Ayúdanos a actualizar esta información con una fuente pública.
        </p>
      )
    }
  </header>

  <div class="grid gap-10 py-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      {description && <p class="prose-reading">{description}</p>}

      {
        notes && (
          <aside class="mt-5 rounded-md border border-inactive/30 bg-inactive-bg/50 p-4 text-sm text-ink-800">
            <p class="kicker text-inactive">Nota de auditoría</p>
            <p class="mt-1">{notes}</p>
          </aside>
        )
      }

      {
        tags.length > 0 && (
          <section class="mt-6">
            <h2 class="kicker">{tagsLabel}</h2>
            <div class="mt-2 flex flex-wrap gap-1.5">
              {tags.map((t) => (
                <Tag label={t} tone="soft" />
              ))}
            </div>
          </section>
        )
      }

      <slot />

      <section class="mt-8 border-t border-ink-200 pt-6">
        <h2 class="font-display text-lg font-semibold text-ink-900">Fuentes</h2>
        {
          sourceList.length > 0 ? (
            <ol class="mt-3 space-y-2">
              {sourceList.map((s, i) => (
                <li class="flex items-baseline gap-2 text-sm">
                  <span class="font-mono text-xs text-ink-400">Fuente {i + 1}</span>
                  <a
                    href={s.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent no-underline hover:underline"
                  >
                    {s.title ?? displayUrl(s.href)}
                    <span aria-hidden="true"> ↗</span>
                    <span class="sr-only">(se abre en una pestaña nueva)</span>
                  </a>
                </li>
              ))}
            </ol>
          ) : (
            <p class="mt-2 text-sm text-ink-500">Sin fuente pública registrada.</p>
          )
        }
        <div class="mt-5">
          <ContributionCTA variant="correct" entityName={entityName ?? title} compact />
        </div>
        <p class="mt-4 text-xs text-ink-500">
          ¿Cómo verificamos e incluimos los registros? <a href="/metodologia" class="link"
            >Metodología y criterios</a
          >.
        </p>
      </section>
    </div>

    <aside class="space-y-6">
      {
        facts.length > 0 && (
          <div class="bg-mist/50 rounded-lg border border-ink-200 p-5">
            <h2 class="kicker">Ficha</h2>
            <dl class="mt-3 space-y-3">
              {facts.map((f) => (
                <div>
                  <dt class="text-xs text-ink-500">{f.label}</dt>
                  <dd class:list={['text-sm text-ink-900', f.mono && 'font-mono']}>{f.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        )
      }

      {
        links.length > 0 && (
          <div class="rounded-lg border border-ink-200 bg-surface p-5">
            <h2 class="kicker">Enlaces</h2>
            <ul class="mt-3 space-y-2">
              {links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-accent no-underline hover:underline"
                  >
                    <span class="font-medium">{l.label}</span>{' '}
                    <span class="break-all text-ink-400">{displayUrl(l.href)}</span>
                    <span aria-hidden="true"> ↗</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <slot name="aside" />
    </aside>
  </div>
</article>
