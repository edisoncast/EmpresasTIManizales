---
export interface Stat {
  label: string;
  value: number;
  href?: string;
  note?: string;
}
export interface Props {
  stats: Stat[];
  /** Nota de corte temporal / aclaración (registros, no indicadores). */
  caption?: string;
}
const { stats, caption } = Astro.props;
---

<div>
  <ul
    class="grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-ink-200 bg-ink-200 sm:grid-cols-3 lg:grid-cols-6"
  >
    {
      stats.map((s) => {
        const inner = (
          <>
            <span class="block font-display text-2xl font-semibold tabular-nums text-ink-900">
              {s.value}
            </span>
            <span class="mt-1 block text-sm text-ink-600">{s.label}</span>
            {s.note && <span class="mt-0.5 block font-mono text-xs text-ink-400">{s.note}</span>}
          </>
        );
        return s.href ? (
          <li class="bg-surface">
            <a
              href={s.href}
              class="hover:bg-accent-soft/40 group block h-full p-4 no-underline transition-colors duration-fast"
            >
              {inner}
            </a>
          </li>
        ) : (
          <li class="bg-surface p-4">{inner}</li>
        );
      })
    }
  </ul>
  {caption && <p class="mt-3 text-xs text-ink-500">{caption}</p>}
</div>
