---
import { site, nav } from '../lib/site';
---

<footer class="bg-mist/60 mt-24 border-t border-ink-200">
  <div class="container-content grid gap-10 py-14 md:grid-cols-12">
    <div class="md:col-span-5">
      <p class="font-display text-lg font-semibold text-ink-900">
        Observatorio TIC · Manizales y Caldas
      </p>
      <p class="mt-3 max-w-sm text-sm leading-relaxed text-ink-600">
        Un mapa abierto del ecosistema tecnológico regional: empresas, universidades, programas,
        personas, comunidades y eventos. Datos abiertos, verificables y mantenidos por comunidad.
      </p>
    </div>

    <nav aria-label="Explorar el ecosistema" class="md:col-span-3">
      <h2 class="kicker">Explorar</h2>
      <ul class="mt-3 space-y-2">
        {
          nav.slice(0, 6).map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-ink-600 no-underline transition-colors duration-fast hover:text-accent"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav aria-label="El proyecto" class="md:col-span-2">
      <h2 class="kicker">Proyecto</h2>
      <ul class="mt-3 space-y-2">
        <li>
          <a href="/ecosistema" class="text-sm text-ink-600 no-underline hover:text-accent"
            >Ecosistema</a
          >
        </li>
        <li>
          <a href="/acerca" class="text-sm text-ink-600 no-underline hover:text-accent"
            >Acerca y metodología</a
          >
        </li>
        <li>
          <a href="/contribuir" class="text-sm text-ink-600 no-underline hover:text-accent"
            >Cómo contribuir</a
          >
        </li>
        <li>
          <a
            href={site.repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-ink-600 no-underline hover:text-accent">Repositorio</a
          >
        </li>
      </ul>
    </nav>

    <div class="md:col-span-2">
      <h2 class="kicker">Contribuir</h2>
      <p class="mt-3 text-sm text-ink-600">
        ¿Falta un dato o una fuente? Ayúdanos a mantener el archivo al día.
      </p>
      <a href="/contribuir" class="btn-secondary mt-4 inline-flex">Sugerir o corregir</a>
    </div>
  </div>

  <div class="border-t border-ink-200">
    <div
      class="container-content flex flex-col gap-2 py-6 text-xs text-ink-500 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>Contenido bajo licencia CC BY-SA 4.0 · {site.author}.</p>
      <p>Proyecto construido por Jhon Edison Castro para la comunidad.</p>
    </div>
  </div>
</footer>
